{
  "_meta": {
    "title": "LONGIN SANCTUARY — Text to Image (Character Consistency)",
    "description": "T2I workflow with IP-Adapter FaceID Plus V2 + ControlNet OpenPose + Character LoRA",
    "version": "1.0",
    "priority": "face_consistency > anatomy > prompt_adherence > speed"
  },
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": {"title": "Base Model Loader"},
    "inputs": {
      "ckpt_name": "flux1-dev.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Positive Prompt"},
    "inputs": {
      "text": "POSITIVE_PROMPT_PLACEHOLDER",
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": {"title": "Negative Prompt"},
    "inputs": {
      "text": "blurry, deformed, ugly, bad anatomy, extra limbs, missing limbs, disfigured, out of focus, low quality, watermark",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptyLatentImage",
    "_meta": {"title": "Latent Image"},
    "inputs": {
      "width": 1024,
      "height": 1024,
      "batch_size": 3
    }
  },
  "5": {
    "class_type": "IPAdapterFaceID",
    "_meta": {"title": "IP-Adapter FaceID (Character Face Lock)"},
    "inputs": {
      "model": ["1", 0],
      "ipadapter": "ip-adapter-faceid-plusv2_sd15.bin",
      "image": ["REFERENCE_IMAGE_NODE", 0],
      "weight": 0.8,
      "weight_v2": 0.8,
      "combine_embeds": "average",
      "start_at": 0.0,
      "end_at": 1.0,
      "embeds_scaling": "V only"
    }
  },
  "6": {
    "class_type": "ControlNetLoader",
    "_meta": {"title": "ControlNet OpenPose (Body Anatomy Lock)"},
    "inputs": {
      "control_net_name": "control_openpose-fp16.safetensors"
    }
  },
  "7": {
    "class_type": "DWPreprocessor",
    "_meta": {"title": "DW Pose Estimator"},
    "inputs": {
      "image": ["POSE_REFERENCE_NODE", 0],
      "detect_hand": "enable",
      "detect_body": "enable",
      "detect_face": "enable",
      "resolution": 512
    }
  },
  "8": {
    "class_type": "ControlNetApplyAdvanced",
    "_meta": {"title": "Apply ControlNet Pose"},
    "inputs": {
      "positive": ["2", 0],
      "negative": ["3", 0],
      "control_net": ["6", 0],
      "image": ["7", 0],
      "strength": 0.7,
      "start_percent": 0.0,
      "end_percent": 0.7
    }
  },
  "9": {
    "class_type": "LoraLoader",
    "_meta": {"title": "Character LoRA (Optional)"},
    "inputs": {
      "model": ["5", 0],
      "clip": ["1", 1],
      "lora_name": "CHARACTER_LORA_PLACEHOLDER",
      "strength_model": 0.8,
      "strength_clip": 0.8
    }
  },
  "10": {
    "class_type": "KSampler",
    "_meta": {"title": "KSampler"},
    "inputs": {
      "model": ["9", 0],
      "positive": ["8", 0],
      "negative": ["8", 1],
      "latent_image": ["4", 0],
      "seed": -1,
      "steps": 30,
      "cfg": 7.0,
      "sampler_name": "euler",
      "scheduler": "karras",
      "denoise": 1.0
    }
  },
  "11": {
    "class_type": "VAEDecode",
    "_meta": {"title": "VAE Decode"},
    "inputs": {
      "samples": ["10", 0],
      "vae": ["1", 2]
    }
  },
  "12": {
    "class_type": "UpscaleModelLoader",
    "_meta": {"title": "RealESRGAN Upscaler"},
    "inputs": {
      "model_name": "RealESRGAN_x4plus.pth"
    }
  },
  "13": {
    "class_type": "ImageUpscaleWithModel",
    "_meta": {"title": "Upscale 4x"},
    "inputs": {
      "upscale_model": ["12", 0],
      "image": ["11", 0]
    }
  },
  "14": {
    "class_type": "SaveImage",
    "_meta": {"title": "Save Output (x3 for triple-check)"},
    "inputs": {
      "images": ["13", 0],
      "filename_prefix": "sanctuary/char_t2i"
    }
  }
}
