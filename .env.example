# Environment variables template for LONGIN SANCTUARY
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# ── Application ─────────────────────────────────────────────
APP_NAME=LONGIN_SANCTUARY
APP_ENV=development
SECRET_KEY=change-this-to-a-random-secret-key-minimum-32-chars
DEBUG=true

# ── Backend API ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.15:3000

# ── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ── PostgreSQL (LTM Database) ───────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=longin_sanctuary
POSTGRES_USER=sanctuary
POSTGRES_PASSWORD=change-this-password

# ── Redis (STM / Session Cache) ─────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Qdrant (Vector DB for RAG) ──────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# ── ComfyUI ─────────────────────────────────────────────────
# Primary ComfyUI server (main node - CORE-DT)
COMFYUI_PRIMARY_URL=http://192.168.1.15:8188
# Additional ComfyUI servers (comma separated)
COMFYUI_EXTRA_URLS=http://192.168.1.18:8188

# ── Ollama (Local LLM) ──────────────────────────────────────
OLLAMA_PRIMARY_URL=http://192.168.1.15:11434
OLLAMA_EXTRA_URLS=http://192.168.1.18:11434

# ── LM Studio (Local OpenAI compatible) ─────────────────────
LMSTUDIO_PRIMARY_URL=http://localhost:1234
LMSTUDIO_ENABLED=true
LMSTUDIO_EXTRA_URLS=


# ── exo (Distributed LLM) ───────────────────────────────────
EXO_ENABLED=true
EXO_PORT=5678
EXO_API_URL=http://localhost:52415

# ── LLM Settings ────────────────────────────────────────────
DEFAULT_LLM_MODEL=llama3.1:8b
DEFAULT_TEMPERATURE=0.8
DEFAULT_MAX_TOKENS=4096
DEFAULT_CONTEXT_LENGTH=8192

# ── Memory Settings ─────────────────────────────────────────
STM_MAX_TOKENS=4096
LTM_SUMMARIZE_THRESHOLD=8000
RAG_TOP_K=5
RAG_SIMILARITY_THRESHOLD=0.75
EMBEDDING_MODEL=nomic-embed-text

# ── Image Generation ────────────────────────────────────────
DEFAULT_IMAGE_MODEL=flux_dev
DEFAULT_IMAGE_STEPS=30
DEFAULT_IMAGE_CFG=7.0
DEFAULT_IMAGE_WIDTH=1024
DEFAULT_IMAGE_HEIGHT=1024
IP_ADAPTER_STRENGTH=0.8
FACE_CONSISTENCY_THRESHOLD=0.85

# ── Video Generation ────────────────────────────────────────
DEFAULT_VIDEO_MODEL=wanvideo
DEFAULT_VIDEO_FRAMES=24
DEFAULT_VIDEO_FPS=8
DEFAULT_VIDEO_WIDTH=832
DEFAULT_VIDEO_HEIGHT=480

# ── Content & Safety ────────────────────────────────────────
NSFW_ENABLED=false
AGE_CHECK_ENABLED=true
AGE_CHECK_MIN_AGE=18
# Content filter level: strict | moderate | permissive
CONTENT_FILTER_LEVEL=moderate

# ── Network Cluster ─────────────────────────────────────────
CLUSTER_DISCOVERY_ENABLED=true
CLUSTER_DISCOVERY_PORT=9999
CLUSTER_SECRET=change-this-cluster-secret
# This node's role: master | worker | both
NODE_ROLE=both
NODE_NAME=CORE-DT

# ── Paths ───────────────────────────────────────────────────
MODELS_PATH=./model_weights
OUTPUT_PATH=./output
COMFYUI_PATH=./comfyui
LORA_PATH=./model_weights/loras
